{
    "$schema":  "https://openapi.vercel.sh/vercel.json",
    "framework":  "nextjs",
    "buildCommand":  "npm run vercel-build",
    "functions":  {
                      "src/app/api/**/route.{ts,js}":  {
                                                           "maxDuration":  30
                                                       },
                      "src/app/api/cron/**/route.{ts,js}":  {
                                                                "maxDuration":  60
                                                            }
                  },
    "crons":  [
                  {
                      "path":  "/api/cron/show-lifecycle",
                      "schedule":  "* * * * *"
                  },
                  {
                      "path":  "/api/cron/expire-reservations",
                      "schedule":  "*/5 * * * *"
                  },
                  {
                      "path":  "/api/digest",
                      "schedule":  "0 10 * * 1"
                  },
                  {
                      "path":  "/api/health-check-cron",
                      "schedule":  "*/15 * * * *"
                  }
              ]
}
