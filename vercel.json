{
    "$schema":  "https://openapi.vercel.sh/vercel.json",
    "framework":  "nextjs",
    "buildCommand":  "npm run vercel-build",
    "functions":  {
                      "src/app/api/**/route.{ts,js}":  {
                                                           "maxDuration":  30
                                                       },
                      "src/app/api/cron/**/route.{ts,js}":  {
                                                                "maxDuration":  60
                                                            }
                  },
    "crons":  [
                  {
                      "path":  "/api/cron/show-lifecycle",
                      "schedule":  "* * * * *"
                  },
                  {
                      "path":  "/api/cron/expire-reservations",
                      "schedule":  "*/5 * * * *"
                  },
                  {
                      "path":  "/api/cron/digest",
                      "schedule":  "0 10 * * 1"
                  },
                  {
                      "path":  "/api/cron/health-check",
                      "schedule":  "*/15 * * * *"
                  },
                  {
                      "path":  "/api/cron/artist-digest",
                      "schedule":  "0 10 * * 2"
                  },
                  {
                      "path":  "/api/cron/onboarding",
                      "schedule":  "0 9 * * *"
                  },
                  {
                      "path":  "/api/cron/show-reminders",
                      "schedule":  "0 */6 * * *"
                  },
                  {
                      "path":  "/api/cron/db-health",
                      "schedule":  "0 8 * * 1"
                  },
                  {
                      "path":  "/api/cron/weekly-picks",
                      "schedule":  "0 9 * * 5"
                  },
                  {
                      "path":  "/api/cron/admin-report",
                      "schedule":  "0 8 * * 1"
                  },
                  {
                      "path":  "/api/cron/new-to-scene",
                      "schedule":  "0 10 * * 3"
                  },
                  {
                      "path":  "/api/cron/expire-ads",
                      "schedule":  "0 3 * * *"
                  },
                  {
                      "path":  "/api/cron/feature-shows",
                      "schedule":  "0 6 * * *"
                  },
                  {
                      "path":  "/api/cron/flag-spam",
                      "schedule":  "0 4 * * *"
                  },
                  {
                      "path":  "/api/cron/show-payouts",
                      "schedule":  "0 5 * * *"
                  },
                  {
                      "path":  "/api/cron/artist-onboarding",
                      "schedule":  "0 11 * * *"
                  },
                  {
                      "path":  "/api/cron/close-stale-bookings",
                      "schedule":  "0 3 * * *"
                  },
                  {
                      "path":  "/api/cron/follow-digest",
                      "schedule":  "0 9 * * *"
                  },
                  {
                      "path":  "/api/cron/session-cleanup",
                      "schedule":  "0 2 * * 0"
                  },
                  {
                      "path":  "/api/cron/audit-log-rotate",
                      "schedule":  "0 1 * * 0"
                  },
                  {
                      "path":  "/api/cron/stripe-connect-health",
                      "schedule":  "0 8 * * 1"
                  }
              ]
}
