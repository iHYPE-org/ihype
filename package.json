{
  "name": "ihype",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "guard:design": "node scripts/guard-claude-design.mjs",
    "start": "next start",
    "lint": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:flows": "node scripts/flow-smoke-test.mjs",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prebuild": "npm run guard:design",
    "prevercel-build": "npm run guard:design",
    "vercel-build": "prisma generate && prisma migrate deploy && next build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@mux/mux-node": "^12.8.1",
    "@prisma/client": "^6.19.3",
    "@prisma/extension-accelerate": "^1.0.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^8.0.7",
    "openai": "^6.27.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^17.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^16.4.5",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
