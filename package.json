{
  "name": "ihype",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run guard:design",
    "build": "next build --webpack",
    "guard:design": "node scripts/guard-claude-design.mjs",
    "start": "next start",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:launch": "tsx prisma/launch-seed.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "smoke:production": "node scripts/smoke-production.mjs",
    "admin:reset-test-logins": "node scripts/reset-test-logins.mjs",
    "analyze": "ANALYZE=true npm run build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy worker.js --experimental-autoconfig=false"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@auth/prisma-adapter": "2.11.2",
    "@mux/mux-node": "^12.8.1",
    "@opennextjs/cloudflare": "^1.7.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^8.55.2",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.3",
    "bcryptjs": "^2.4.3",
    "next": "^16.2.4",
    "next-auth": "5.0.0-beta.31",
    "openai": "^6.27.0",
    "pg": "^8.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^17.7.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^16.4.5",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.93.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next-auth": "5.0.0-beta.31",
    "@auth/prisma-adapter": "2.11.2"
  }
}
