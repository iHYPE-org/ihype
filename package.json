{
  "name": "ihype",
  "version": "1.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "npm run guard:design && node scripts/bump-sw-version.mjs",
    "build": "next build --webpack",
    "guard:design": "node scripts/guard-claude-design.mjs",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint-source.mjs",
    "check": "npm run typecheck && npm run lint && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:launch": "tsx prisma/launch-seed.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "smoke:production": "node scripts/smoke-production.mjs",
    "admin:reset-test-logins": "node scripts/reset-test-logins.mjs",
    "analyze": "ANALYZE=true npm run build",
    "cf:build": "node scripts/bump-sw-version.mjs && opennextjs-cloudflare build && node scripts/patch-worker-bundle.mjs",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy worker.js --autoconfig=false",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.3",
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/push-notifications": "^8.1.2",
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "^7.9.0",
    "@sentry/cloudflare": "10.67.0",
    "@sentry/nextjs": "^10.67.0",
    "@simplewebauthn/browser": "^13.0.0",
    "@simplewebauthn/server": "^13.3.2",
    "bcryptjs": "^3.0.3",
    "next": "16.2.11",
    "next-auth": "5.0.0-beta.32",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.3.2",
    "uqr": "^0.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.5",
    "@vitest/coverage-v8": "^4.1.10",
    "chrome-launcher": "^1.2.1",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "lighthouse": "^13.4.1",
    "prisma": "^7.9.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next-auth": "5.0.0-beta.32",
    "@auth/prisma-adapter": "2.11.3",
    "sharp": "^0.35.3"
  }
}
