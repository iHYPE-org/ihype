{
    "name": "ihype",
    "version": "1.0.0",
    "private": true,
    "packageManager": "npm@10.9.2",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "postinstall": "prisma generate",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:seed": "tsx prisma/seed.ts",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "analyze": "ANALYZE=true npm run build",
        "cf:build": "opennextjs-cloudflare build",
        "cf:dev": "wrangler pages dev",
        "cf:deploy": "node scripts/guard-github-deploy-source.mjs pages && wrangler pages deploy .open-next/assets --project-name=ihype --branch=main",
        "cf:deploy:cron": "node scripts/guard-github-deploy-source.mjs cron && wrangler deploy --config wrangler.cron.toml"
    },
    "dependencies": {
        "@auth/prisma-adapter": "2.11.2",
        "@opennextjs/cloudflare": "^1.7.0",
        "@prisma/client": "^6.19.3",
        "@prisma/extension-accelerate": "^1.0.0",
        "@sentry/nextjs": "^8.0.0",
        "@types/qrcode": "^1.5.6",
        "bcryptjs": "^2.4.3",
        "next": "^16.2.4",
        "next-auth": "5.0.0-beta.31",
        "openai": "^6.27.0",
        "qrcode": "^1.5.4",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "stripe": "^17.7.0",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@next/bundle-analyzer": "^15.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^22.15.30",
        "@types/react": "^19.1.6",
        "@types/react-dom": "^19.1.5",
        "@vitest/coverage-v8": "^2.1.9",
        "dotenv": "^16.4.5",
        "prisma": "^6.19.3",
        "tsx": "^4.19.2",
        "typescript": "^5.8.3",
        "vitest": "^2.1.9",
        "wrangler": "^4.59.2"
    },
    "overrides": {
        "postcss": "^8.5.10",
        "next-auth": "5.0.0-beta.31",
        "@auth/prisma-adapter": "2.11.2"
    }
}
