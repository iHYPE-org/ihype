{
  "name": "ihype",
  "version": "1.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run guard:design && node scripts/bump-sw-version.mjs",
    "build": "next build --webpack",
    "guard:design": "node scripts/guard-claude-design.mjs",
    "start": "next start",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:launch": "tsx prisma/launch-seed.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "smoke:production": "node scripts/smoke-production.mjs",
    "admin:reset-test-logins": "node scripts/reset-test-logins.mjs",
    "analyze": "ANALYZE=true npm run build",
    "cf:build": "node scripts/bump-sw-version.mjs && opennextjs-cloudflare build && node scripts/patch-worker-bundle.mjs",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy worker.js --autoconfig=false",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.2",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@opennextjs/cloudflare": "^1.7.0",
    "@prisma/adapter-pg": "6.19.3",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.57.0",
    "@simplewebauthn/browser": "^13.0.0",
    "@simplewebauthn/server": "^13.0.0",
    "bcryptjs": "^2.4.3",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^17.7.0",
    "uqr": "^0.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.0.0",
    "@playwright/test": "^1.49.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^16.4.5",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.93.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next-auth": "5.0.0-beta.31",
    "@auth/prisma-adapter": "2.11.2"
  }
}
