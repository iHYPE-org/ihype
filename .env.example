DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Use a direct/non-pooled Postgres URL for Prisma migrations. Deployment maps
# this value to DATABASE_URL only for `prisma migrate deploy`.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-at-least-32-random-bytes"
AUTH_URL="https://ihype.org"
NEXT_PUBLIC_APP_URL="https://ihype.org"

# Email powers sign-in MFA, password reset, and ticket emails.
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
EMAIL_FROM="iHYPE <no-reply@ihype.org>"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-username"
SMTP_PASSWORD="smtp-password"
SMTP_FROM="iHYPE <no-reply@ihype.org>"

# Optional platform integrations.
OPENAI_API_KEY=""
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""
BLOB_READ_WRITE_TOKEN=""

# Paid ticketing stays disabled until Stripe/nonprofit onboarding is complete.
# Supplying Stripe credentials alone does not enable charges.
FEATURE_ENABLE_TICKET_PAYMENTS="false"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_AD_WEBHOOK_SECRET=""

# REQUIRED for closed beta. Generate high-entropy codes rather than memorable
# public words, for example: openssl rand -hex 16
BETA_INVITE_CODES="replace-with-a-random-32-character-code"

# Web Push (VAPID) — required for push notifications.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@ihype.org"

# Native (iOS/Android) push notifications.
FCM_PROJECT_ID=""
FCM_CLIENT_EMAIL=""
FCM_PRIVATE_KEY=""

# Universal Links (iOS) / App Links (Android).
APPLE_TEAM_ID=""
ANDROID_CERT_SHA256_FINGERPRINTS=""

# Production safety switches.
ALLOW_ADMIN_SETUP="false"
ADMIN_SETUP_SECRET=""
ADMIN_DEVICE_SECRET=""
FEATURE_REQUIRE_INVITE_CODE="true"
FEATURE_ALLOW_DATABASE_MEDIA_STORAGE="false"
FEATURE_ENABLE_LIVE_STREAMS="false"

# Sentry error monitoring (optional).
NEXT_PUBLIC_SENTRY_DSN=

# Cloudflare Web Analytics (optional and cookieless).
NEXT_PUBLIC_CF_BEACON_TOKEN=
