DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Use a direct/non-pooled Postgres URL for Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_URL="https://ihype.org"
NEXT_PUBLIC_APP_URL="https://ihype.org"

# Email powers sign-in MFA, password reset, and ticket emails.
# Resend is preferred when RESEND_API_KEY is set; SMTP remains the fallback.
RESEND_API_KEY=""
EMAIL_FROM="iHYPE <no-reply@ihype.org>"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-username"
SMTP_PASSWORD="smtp-password"
SMTP_FROM="iHYPE <no-reply@ihype.org>"

# Optional platform integrations.
OPENAI_API_KEY=""
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""
BLOB_READ_WRITE_TOKEN=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# REQUIRED for closed beta: comma-separated list of valid invite codes.
BETA_INVITE_CODES="IHYPE,HYPE2026,BETA,LISTEN"

# Web Push (VAPID) — required for push notifications.
# Generate with: node scripts/generate-vapid-keys.mjs
# Then set as Cloudflare Worker secrets: wrangler secret put VAPID_PUBLIC_KEY
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@ihype.org"

# Native (iOS/Android) push notifications — required for the Capacitor shell
# to deliver push, separate from the Web Push VAPID keys above. Needs a
# Firebase project (free to create): download the service account JSON from
# Project Settings → Service Accounts → Generate new private key, then set
# FCM_CLIENT_EMAIL/FCM_PRIVATE_KEY from its client_email/private_key fields.
# For iOS delivery, also upload an APNs auth key to that same Firebase
# project's Cloud Messaging settings (needs a paid Apple Developer account).
FCM_PROJECT_ID=""
FCM_CLIENT_EMAIL=""
FCM_PRIVATE_KEY=""

# Universal Links (iOS) / App Links (Android) — lets ihype.org links open
# directly in the native app instead of the browser. Both are safe to leave
# blank (the .well-known routes serve an inert placeholder); fill in once
# the corresponding developer account exists.
# Apple Developer Program → Membership → Team ID.
APPLE_TEAM_ID=""
# SHA-256 fingerprint(s) of the Android signing/upload certificate,
# comma-separated if there's more than one (e.g. Play "app signing" + a local
# upload key). Get via: keytool -list -v -keystore your.keystore
ANDROID_CERT_SHA256_FINGERPRINTS=""

# Production safety switches.
# Temporarily set both values only during first admin bootstrap, then remove/disable them.
ALLOW_ADMIN_SETUP="false"
ADMIN_SETUP_SECRET=""
ADMIN_DEVICE_SECRET=""
# REQUIRED for closed beta: keep true until public launch.
FEATURE_REQUIRE_INVITE_CODE="true"
# Keep database media uploads off in production unless a temporary admin-only exception is needed.
FEATURE_ALLOW_DATABASE_MEDIA_STORAGE="false"
# Live streaming is disabled by default; promoter shows are prerecorded radio-style shows.
FEATURE_ENABLE_LIVE_STREAMS="false"

# Sentry error monitoring (optional — leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=

# Cloudflare Web Analytics (optional — leave blank to disable).
# Free for nonprofits. Get the token from the Cloudflare dashboard:
# Analytics & Logs → Web Analytics → Add a site → copy the "token" value
# from the generated <script data-cf-beacon='{"token":"..."}'> snippet.
# Cookieless — no consent banner required for this specific tracker.
NEXT_PUBLIC_CF_BEACON_TOKEN=
